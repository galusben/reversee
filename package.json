{
  "name": "reversee",
  "version": "2.1.0",
  "type": "module",
  "main": "./out/main/index.js",
  "productName": "Reversee",
  "description": "Reverse Proxy Web Debugger",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "mcp"
  ],
  "scripts": {
    "start": "electron-vite dev",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "test": "vitest run",
    "build:mcp": "npm run build -w reversee-mcp",
    "typecheck": "tsc --build && tsc -p mcp --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "clsx": "^2.1.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-vite": "^5.0.0",
    "electron-window-state": "^5.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.4.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "ninja.reversee",
    "productName": "Reversee",
    "files": [
      "out/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "galusben",
      "repo": "reversee"
    }
  },
  "author": {
    "name": "Gal Ben Ami",
    "email": "galusben@gmail.com"
  },
  "homepage": "https://reversee.ninja"
}
